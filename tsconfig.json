{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@messages/*": ["src/messages/*"],
      "@transport/*": ["src/transport/*"],
      "@plugin/*": ["src/runtime-plugin/*"],
      "@daemon/*": ["src/runtime-daemon/*"]
    },
    "types": ["bun-types"]
  },
  "include": ["src"]
}
